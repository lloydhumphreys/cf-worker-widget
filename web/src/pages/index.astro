---
import Layout from '../layouts/Layout.astro';
---

<Layout title="WorkerWidget — Cloudflare build monitor for macOS">
  <!-- macOS Menu Bar -->
  <div class="menubar">
    <div class="menubar-left">
      <span class="menubar-app">WorkerWidget</span>
      <div class="menubar-dropdown">
        <span>File</span>
        <div class="menubar-dropdown-menu">
          <a href="https://github.com/lloydhumphreys/cf-worker-widget/releases/latest" target="_blank" class="menubar-dropdown-item">Download WorkerWidget</a>
          <a href="https://github.com/lloydhumphreys/cf-worker-widget" target="_blank" class="menubar-dropdown-item">Open GitHub</a>
          <a href="https://github.com/lloydhumphreys/cf-worker-widget/blob/main/LICENSE" target="_blank" class="menubar-dropdown-item"><span>License</span><span class="menubar-shortcut">&#8984;I</span></a>
          <div class="menubar-dropdown-divider"></div>
          <button class="menubar-dropdown-item" id="menu-quit">Quit</button>
        </div>
      </div>
      <div class="menubar-dropdown">
        <span>Help</span>
        <div class="menubar-dropdown-menu">
          <a href="#faq" class="menubar-dropdown-item" id="menu-faq">FAQ</a>
          <div class="menubar-dropdown-divider"></div>
          <a href="https://x.com/lloyd" target="_blank" class="menubar-dropdown-item">DM @Lloyd</a>
          <a href="https://github.com/lloydhumphreys/cf-worker-widget/issues" target="_blank" class="menubar-dropdown-item">GitHub Issues</a>
        </div>
      </div>
    </div>
    <div class="menubar-right">
      <button class="menubar-tray-icon" id="menubar-tray-icon" aria-label="Toggle WorkerWidget">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m17 15-5.5 5.5L9 18"/><path d="M5.516 16.07A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 3.501 7.327"/></svg>
      </button>
      <span class="menubar-clock" id="menubar-clock">Wed 9 Apr 3:42 PM</span>
    </div>
  </div>

  <!-- Popover widget (drops from menubar) -->
  <div class="widget-popover" id="widget-popover">
    <div class="widget">
      <div class="widget-toolbar" id="widget-toolbar"></div>
      <div class="widget-content">
        <div class="widget-view" id="widget-list-view"></div>
        <div class="widget-view widget-detail-view" id="widget-detail-view"></div>
      </div>
    </div>
  </div>

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <img src="/app-icon.png" alt="WorkerWidget icon" class="app-icon" />
        <h1>WorkerWidget</h1>
        <p class="tagline">Monitor your Cloudflare Workers builds from the menu bar.</p>
        <div class="cta-group">
          <a href="https://github.com/lloydhumphreys/cf-worker-widget/releases/latest" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M17 9.00195C19.175 9.01406 20.3529 9.11051 21.1213 9.8789C22 10.7576 22 12.1718 22 15.0002V16.0002C22 18.8286 22 20.2429 21.1213 21.1215C20.2426 22.0002 18.8284 22.0002 16 22.0002H8C5.17157 22.0002 3.75736 22.0002 2.87868 21.1215C2 20.2429 2 18.8286 2 16.0002L2 15.0002C2 12.1718 2 10.7576 2.87868 9.87889C3.64706 9.11051 4.82497 9.01406 7 9.00195"/><path d="M12 2L12 15M12 15L9 11.5M12 15L15 11.5" stroke-linejoin="round"/></svg>
            Download for macOS
          </a>
          <a href="https://github.com/lloydhumphreys/cf-worker-widget" class="btn btn-secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M17 7.82959L18.6965 9.35641C20.239 10.7447 21.0103 11.4389 21.0103 12.3296C21.0103 13.2203 20.239 13.9145 18.6965 15.3028L17 16.8296"/><path d="M13.9868 5L12 12.4149L10.0132 19.8297"/><path d="M7.00005 7.82959L5.30358 9.35641C3.76102 10.7447 2.98975 11.4389 2.98975 12.3296C2.98975 13.2203 3.76102 13.9145 5.30358 15.3028L7.00005 16.8296"/></svg>
            View on GitHub
          </a>
        </div>
        <div class="install-brew">
          <span class="label">or install with Homebrew</span>
          <code>brew install --cask workerwidget</code>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="features" id="features">
      <div class="container">
        <div class="features-grid">
          <div class="feature">
            <div class="feature-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M6.28571 19C3.91878 19 2 17.1038 2 14.7647C2 12.4256 3.91878 10.5294 6.28571 10.5294C6.56983 10.5294 6.8475 10.5567 7.11616 10.6089M14.381 8.02721C14.9767 7.81911 15.6178 7.70588 16.2857 7.70588C16.9404 7.70588 17.5693 7.81468 18.1551 8.01498M7.11616 10.6089C6.88706 9.9978 6.7619 9.33687 6.7619 8.64706C6.7619 5.52827 9.32028 3 12.4762 3C15.4159 3 17.8371 5.19371 18.1551 8.01498M7.11616 10.6089C7.68059 10.7184 8.20528 10.9374 8.66667 11.2426M18.1551 8.01498C20.393 8.78024 22 10.8811 22 13.3529C22 16.0599 20.0726 18.3221 17.5 18.8722"/><path d="M10 19.8L11.1429 21L14 18" stroke-linejoin="round"/></svg></div>
            <h3>Live build status</h3>
            <p>See Workers and Pages deployments update in real time, right from your menu bar.</p>
          </div>
          <div class="feature">
            <div class="feature-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18.7491 9.70957V9.00497C18.7491 5.13623 15.7274 2 12 2C8.27256 2 5.25087 5.13623 5.25087 9.00497V9.70957C5.25087 10.5552 5.00972 11.3818 4.5578 12.0854L3.45036 13.8095C2.43882 15.3843 3.21105 17.5249 4.97036 18.0229C9.57274 19.3257 14.4273 19.3257 19.0296 18.0229C20.789 17.5249 21.5612 15.3843 20.5496 13.8095L19.4422 12.0854C18.9903 11.3818 18.7491 10.5552 18.7491 9.70957Z"/><path d="M7.5 19C8.15503 20.7478 9.92246 22 12 22C14.0775 22 15.845 20.7478 16.5 19" stroke-linecap="round"/></svg></div>
            <h3>Failure notifications</h3>
            <p>Get a native macOS notification the moment a build fails.</p>
          </div>
          <div class="feature">
            <div class="feature-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M10 15H12C15.3137 15 18 12.3137 18 9C18 5.68629 15.3137 3 12 3H8C4.68629 3 2 5.68629 2 9C2 10.5367 2.57771 11.9385 3.52779 13M14 9H12C8.68629 9 6 11.6863 6 15C6 18.3137 8.68629 21 12 21H16C19.3137 21 22 18.3137 22 15C22 13.4633 21.4223 12.0615 20.4722 11"/></svg></div>
            <h3>One-click to dashboard</h3>
            <p>Click any build to jump straight to its page in the Cloudflare dashboard.</p>
          </div>
          <div class="feature">
            <div class="feature-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 16C2 13.1716 2 11.7574 2.87868 10.8787C3.75736 10 5.17157 10 8 10H16C18.8284 10 20.2426 10 21.1213 10.8787C22 11.7574 22 13.1716 22 16C22 18.8284 22 20.2426 21.1213 21.1213C20.2426 22 18.8284 22 16 22H8C5.17157 22 3.75736 22 2.87868 21.1213C2 20.2426 2 18.8284 2 16Z"/><circle cx="12" cy="16" r="2"/><path d="M6 10V8C6 4.68629 8.68629 2 12 2C15.3137 2 18 4.68629 18 8V10" stroke-linecap="round"/></svg></div>
            <h3>Keychain storage</h3>
            <p>Your API token is stored securely in the macOS Keychain. Never touches disk.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq" id="faq">
      <div class="container">
        <h2>FAQ</h2>
        <div class="faq-list">
          <details>
            <summary>What API permissions does my token need?</summary>
            <p>Your Cloudflare API token needs <strong>Workers Scripts: Read</strong>, <strong>Workers Builds Configuration: Read</strong> (for Workers with GitHub integration), and <strong>Pages: Read</strong>.</p>
          </details>
          <details>
            <summary>Is my API token stored securely?</summary>
            <p>Yes. Your token is stored in the macOS Keychain and never written to disk or transmitted anywhere other than the Cloudflare API.</p>
          </details>
          <details>
            <summary>Does it support multiple Cloudflare accounts?</summary>
            <p>Yes. WorkerWidget automatically discovers all accounts your API token has access to and shows projects from each.</p>
          </details>
          <details>
            <summary>How often does it refresh?</summary>
            <p>By default every 5 minutes, but you can change the refresh interval in Settings.</p>
          </details>
          <details>
            <summary>Does it auto-update?</summary>
            <p>Yes. WorkerWidget uses Sparkle for seamless in-app updates. You'll get a prompt when a new version is available.</p>
          </details>
          <details>
            <summary>Is this affiliated with Cloudflare?</summary>
            <p>No. This is an independent project. We just really like Cloudflare.</p>
          </details>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer>
      <div class="container">
        <p>
          MIT License &middot;
          <a href="https://github.com/lloydhumphreys/cf-worker-widget">GitHub</a> &middot;
          <a href="https://github.com/lloydhumphreys/cf-worker-widget/releases">Releases</a>
        </p>
      </div>
    </footer>
  </main>
</Layout>

<style>
  .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Hero */
  .hero {
    text-align: center;
    padding: 80px 24px 80px;
  }

  .app-icon {
    width: 120px;
    height: 120px;
    border-radius: 26px;
    margin-bottom: 32px;
    filter: drop-shadow(0 8px 32px rgba(251, 146, 60, 0.25));
  }

  h1 {
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 12px;
    background: linear-gradient(135deg, #fff 0%, #a3a3a3 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .tagline {
    font-size: 1.2rem;
    color: #a3a3a3;
    max-width: 440px;
    margin: 0 auto 40px;
  }

  .cta-group {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 10px;
    font-size: 0.95rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: linear-gradient(135deg, #f97316, #ea580c);
    color: #fff;
  }

  .btn-primary:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #e5e5e5;
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateY(-1px);
  }

  .install-brew {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .install-brew .label {
    font-size: 0.8rem;
    color: #737373;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .install-brew code {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 10px 20px;
    border-radius: 8px;
    font-size: 0.9rem;
    color: #fb923c;
    font-family: 'SF Mono', 'Fira Code', monospace;
    user-select: all;
  }

  /* Features */
  .features {
    padding: 60px 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  .feature {
    padding: 24px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .feature-icon {
    margin-bottom: 12px;
    color: #fb923c;
  }

  .feature-icon svg {
    width: 28px;
    height: 28px;
  }

  .feature h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 6px;
    color: #f5f5f5;
  }

  .feature p {
    font-size: 0.9rem;
    color: #a3a3a3;
    line-height: 1.5;
  }

  .faq h2 {
    font-size: 1.8rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 32px;
    text-align: center;
    color: #f5f5f5;
  }

  /* FAQ */
  .faq {
    padding: 60px 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .faq-list {
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  details {
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  summary {
    padding: 16px 0;
    font-size: 0.95rem;
    font-weight: 500;
    color: #e5e5e5;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  summary::after {
    content: '+';
    font-size: 1.2rem;
    color: #737373;
    transition: transform 0.2s;
  }

  details[open] summary::after {
    content: '\2212';
  }

  summary::-webkit-details-marker {
    display: none;
  }

  details p {
    padding: 0 0 16px;
    font-size: 0.9rem;
    color: #a3a3a3;
    line-height: 1.6;
  }

  /* Footer */
  footer {
    padding: 40px 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    text-align: center;
  }

  footer p {
    font-size: 0.8rem;
    color: #525252;
  }

  footer a {
    color: #737373;
    transition: color 0.2s;
  }

  footer a:hover {
    color: #e5e5e5;
  }

  /* Responsive */
  @media (max-width: 600px) {
    .hero {
      padding: 72px 24px 60px;
    }

    h1 {
      font-size: 2.2rem;
    }

    .tagline {
      font-size: 1rem;
    }

    .features-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }


</style>

<style is:global>
  /* macOS Menu Bar */
  .menubar {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 16px;
    height: 28px;
    background: rgba(30, 30, 30, 0.8);
    backdrop-filter: blur(30px) saturate(1.5);
    -webkit-backdrop-filter: blur(30px) saturate(1.5);
    font-size: 13px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.85);
    font-family: system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    -webkit-font-smoothing: antialiased;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .menubar-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .menubar-left span {
    font-size: 13px;
    font-weight: 500;
    opacity: 0.85;
  }

  .menubar-app {
    font-weight: 600 !important;
    opacity: 1 !important;
  }

  .menubar-dropdown {
    position: relative;
  }

  .menubar-dropdown > span {
    cursor: default;
    padding: 2px 8px;
    border-radius: 4px;
  }

  .menubar-dropdown > span:hover,
  .menubar-dropdown.open > span {
    background: rgba(255, 255, 255, 0.15);
  }

  .menubar-dropdown-menu {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    min-width: 220px;
    background: rgba(40, 40, 40, 0.95);
    backdrop-filter: blur(30px) saturate(1.5);
    -webkit-backdrop-filter: blur(30px) saturate(1.5);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 6px;
    padding: 4px 0;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5);
    z-index: 200;
  }

  .menubar-dropdown.open .menubar-dropdown-menu {
    display: block;
  }

  .menubar-dropdown-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 4px 12px;
    font-size: 13px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    border: none;
    background: none;
    cursor: default;
    font-family: inherit;
    -webkit-font-smoothing: antialiased;
  }

  .menubar-dropdown-item:hover {
    background: #2563eb;
    color: #fff;
    border-radius: 4px;
    margin: 0 4px;
    padding: 4px 8px;
    width: calc(100% - 8px);
  }

  .menubar-shortcut {
    font-size: 12px;
    opacity: 0.5;
  }

  .menubar-dropdown-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin: 4px 0;
  }

  .menubar-tray-icon {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.85);
    cursor: pointer;
    padding: 2px 4px;
    margin: -2px -4px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    transition: background 0.15s;
  }

  .menubar-tray-icon:hover,
  .menubar-tray-icon.active {
    background: rgba(255, 255, 255, 0.15);
  }

  /* Widget popover */
  .widget-popover {
    position: fixed;
    top: 28px;
    right: 100px;
    z-index: 99;
    opacity: 0;
    transform: translateY(-8px) scale(0.97);
    transform-origin: top center;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .widget-popover.open {
    opacity: 1;
    transform: translateY(4px) scale(1);
    pointer-events: auto;
  }

  .inline-icon {
    display: inline-block;
    vertical-align: -3px;
    opacity: 0.7;
  }

  .menubar-right {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .menubar-clock {
    font-size: 13px;
    font-weight: 500;
    opacity: 0.85;
    font-variant-numeric: tabular-nums;
  }

  /* Widget frame — glassy */
  .widget {
    width: 400px;
    background: rgba(244, 244, 244, 0.92);
    backdrop-filter: blur(50px) saturate(1.5);
    -webkit-backdrop-filter: blur(50px) saturate(1.5);
    border-radius: 12px;
    overflow: hidden;
    box-shadow:
      0 0 0 0.5px rgba(0, 0, 0, 0.12),
      0 12px 40px rgba(0, 0, 0, 0.35),
      0 2px 6px rgba(0, 0, 0, 0.12);
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
    color: #1d1d1f;
    font-size: 13px;
    -webkit-font-smoothing: antialiased;
  }

  .widget-content {
    position: relative;
    overflow: hidden;
  }

  .widget-view {
    max-height: 460px;
    overflow-y: auto;
  }

  .widget-detail-view {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    transform: translateX(100%);
    transition: transform 0.25s ease;
    background: rgba(244, 244, 244, 0.92);
    min-height: 100%;
  }

  .widget.detail-mode .widget-detail-view {
    transform: translateX(0);
  }

  .widget.detail-mode #widget-list-view {
    visibility: hidden;
    pointer-events: none;
  }

  /* Detail view rows */
  .detail-header {
    padding: 12px 14px;
    border-bottom: 1px solid #ddd;
  }

  .detail-build {
    padding: 10px 14px;
    border-bottom: 1px solid #e8e8e8;
  }

  .detail-build:last-child {
    border-bottom: none;
  }

  .detail-build-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
  }

  .detail-build-msg {
    font-size: 12.5px;
    color: #333;
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .detail-build-time {
    font-size: 11px;
    color: #999;
    flex-shrink: 0;
  }

  .detail-build-bottom {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 4px;
  }

  .detail-build-duration {
    font-size: 11px;
    color: #999;
    margin-left: auto;
  }

  .toolbar-back {
    display: flex;
    align-items: center;
    gap: 3px;
    background: none;
    border: none;
    color: #888;
    font-size: 12px;
    cursor: pointer;
    padding: 2px 4px;
    margin: -2px -4px;
    border-radius: 4px;
    font-family: inherit;
  }

  .toolbar-back:hover {
    color: #555;
  }

  /* Toolbar */
  .widget-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 14px;
    height: 36px;
    flex-shrink: 0;
    background: transparent;
    border-bottom: 1px solid #d5d5d5;
  }

  .toolbar-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .toolbar-icon {
    opacity: 0.55;
    cursor: pointer;
  }

  .toolbar-icon:hover {
    opacity: 0.8;
  }

  .auto-badge {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    color: #666;
  }

  .auto-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #34c759;
  }

  /* Project rows */
  .widget-project {
    border-bottom: 1px solid #ddd;
    cursor: pointer;
    transition: background 0.15s;
  }

  .widget-project:last-child {
    border-bottom: none;
  }

  .widget-project:hover > .project-row {
    background: rgba(0, 0, 0, 0.03);
  }

  .widget-project.expanded > .project-row {
    background: rgba(0, 0, 0, 0.03);
    border-bottom: 1px solid #ddd;
  }

  .project-row {
    padding: 12px 14px;
    transition: background 0.15s;
  }

  .project-info {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .project-name-line {
    display: flex;
    align-items: center;
    justify-content: space-between;
