  .branch-badge.wrangler {
    background: rgba(249, 115, 22, 0.12);
    color: #c2410c;
  }

  .branch-badge.wrangler::before {
    content: '\25A0';
    font-size: 7px;
    color: #ea580c;
  }

  .branch-badge.main {
    background: rgba(124, 58, 237, 0.1);
    color: #6d28d9;
  }

  .branch-badge.main::before {
    content: '\2191';
    font-size: 10px;
    color: #7c3aed;
  }

  .commit-hash {
    font-size: 11px;
    color: #999;
    font-family: 'SF Mono', 'Menlo', monospace;
  }

  .time-ago {
    font-size: 11px;
