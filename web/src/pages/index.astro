      { msg: 'feat: multi-merchant support', branch: 'main', hash: '917cb3a', status: 'Success', time: '1mo ago', dur: '2m 48s' },
    ]},
  ];

  type Project = typeof projects[0];
  type Build = Project['builds'][0];

  function sc(s: string) { return s === 'Failed' ? 'status-failed' : s === 'Success' ? 'status-success' : 'status-deployed'; }
  function dc(s: string) { return s === 'Failed' ? 'red' : 'green'; }

  const widget = document.querySelector('.widget-popover .widget')!;
  const toolbar = document.getElementById('widget-toolbar')!;
  const listView = document.getElementById('widget-list-view')!;
  const detailView = document.getElementById('widget-detail-view')!;

  // Render toolbar for list mode
  function renderListToolbar() {
    toolbar.innerHTML = `<div class="toolbar-left"><svg class="toolbar-icon refresh-icon" width="13" height="13" viewBox="0 0 24 24" fill="#888"><path fill-rule="evenodd" clip-rule="evenodd" d="M2.93077 11.2003C3.00244 6.23968 7.07619 2.25 12.0789 2.25C15.3873 2.25 18.287 3.99427 19.8934 6.60721C20.1103 6.96007 20.0001 7.42199 19.6473 7.63892C19.2944 7.85585 18.8325 7.74565 18.6156 7.39279C17.2727 5.20845 14.8484 3.75 12.0789 3.75C7.8945 3.75 4.50372 7.0777 4.431 11.1982L4.83138 10.8009C5.12542 10.5092 5.60029 10.511 5.89203 10.8051C6.18377 11.0991 6.18191 11.574 5.88787 11.8657L4.20805 13.5324C3.91565 13.8225 3.44398 13.8225 3.15157 13.5324L1.47176 11.8657C1.17772 11.574 1.17585 11.0991 1.46759 10.8051C1.75933 10.5111 2.2342 10.5092 2.52824 10.8009L2.93077 11.2003ZM19.7864 10.4666C20.0786 10.1778 20.5487 10.1778 20.8409 10.4666L22.5271 12.1333C22.8217 12.4244 22.8245 12.8993 22.5333 13.1939C22.2421 13.4885 21.7673 13.4913 21.4727 13.2001L21.0628 12.7949C20.9934 17.7604 16.9017 21.75 11.8825 21.75C8.56379 21.75 5.65381 20.007 4.0412 17.3939C3.82366 17.0414 3.93307 16.5793 4.28557 16.3618C4.63806 16.1442 5.10016 16.2536 5.31769 16.6061C6.6656 18.7903 9.09999 20.25 11.8825 20.25C16.0887 20.25 19.4922 16.9171 19.5625 12.7969L19.1546 13.2001C18.86 13.4913 18.3852 13.4885 18.094 13.1939C17.8028 12.8993 17.8056 12.4244 18.1002 12.1333L19.7864 10.4666Z"/></svg><span class="auto-badge"><span class="auto-dot"></span>Auto</span></div><svg class="toolbar-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M13.7654 2.15224C13.3978 2 12.9319 2 12 2C11.0681 2 10.6022 2 10.2346 2.15224C9.74457 2.35523 9.35522 2.74458 9.15223 3.23463C9.05957 3.45834 9.0233 3.7185 9.00911 4.09799C8.98826 4.65568 8.70226 5.17189 8.21894 5.45093C7.73564 5.72996 7.14559 5.71954 6.65219 5.45876C6.31645 5.2813 6.07301 5.18262 5.83294 5.15102C5.30704 5.08178 4.77518 5.22429 4.35436 5.5472C4.03874 5.78938 3.80577 6.1929 3.33983 6.99993C2.87389 7.80697 2.64092 8.21048 2.58899 8.60491C2.51976 9.1308 2.66227 9.66266 2.98518 10.0835C3.13256 10.2756 3.3397 10.437 3.66119 10.639C4.1338 10.936 4.43789 11.4419 4.43786 12C4.43783 12.5581 4.13375 13.0639 3.66118 13.3608C3.33965 13.5629 3.13248 13.7244 2.98508 13.9165C2.66217 14.3373 2.51966 14.8691 2.5889 15.395C2.64082 15.7894 2.87379 16.193 3.33973 17C3.80568 17.807 4.03865 18.2106 4.35426 18.4527C4.77508 18.7756 5.30694 18.9181 5.83284 18.8489C6.07289 18.8173 6.31632 18.7186 6.65204 18.5412C7.14547 18.2804 7.73556 18.27 8.2189 18.549C8.70224 18.8281 8.98826 19.3443 9.00911 19.9021C9.02331 20.2815 9.05957 20.5417 9.15223 20.7654C9.35522 21.2554 9.74457 21.6448 10.2346 21.8478C10.6022 22 11.0681 22 12 22C12.9319 22 13.3978 22 13.7654 21.8478C14.2554 21.6448 14.6448 21.2554 14.8477 20.7654C14.9404 20.5417 14.9767 20.2815 14.9909 19.902C15.0117 19.3443 15.2977 18.8281 15.781 18.549C16.2643 18.2699 16.8544 18.2804 17.3479 18.5412C17.6836 18.7186 17.927 18.8172 18.167 18.8488C18.6929 18.9181 19.2248 18.7756 19.6456 18.4527C19.9612 18.2105 20.1942 17.807 20.6601 16.9999C21.1261 16.1929 21.3591 15.7894 21.411 15.395C21.4802 14.8691 21.3377 14.3372 21.0148 13.9164C20.8674 13.7243 20.6602 13.5628 20.3387 13.3608C19.8662 13.0639 19.5621 12.558 19.5621 11.9999C19.5621 11.4418 19.8662 10.9361 20.3387 10.6392C20.6603 10.4371 20.8675 10.2757 21.0149 10.0835C21.3378 9.66273 21.4803 9.13087 21.4111 8.60497C21.3592 8.21055 21.1262 7.80703 20.6602 7C20.1943 6.19297 19.9613 5.78945 19.6457 5.54727C19.2249 5.22436 18.693 5.08185 18.1671 5.15109C17.9271 5.18269 17.6837 5.28136 17.3479 5.4588C16.8545 5.71959 16.2644 5.73002 15.7811 5.45096C15.2977 5.17191 15.0117 4.65566 14.9909 4.09794C14.9767 3.71848 14.9404 3.45833 14.8477 3.23463C14.6448 2.74458 14.2554 2.35523 13.7654 2.15224Z"/></svg>`;
  }

  // Render toolbar for detail mode
  function renderDetailToolbar() {
    toolbar.innerHTML = `<button class="toolbar-back" id="back-btn"><svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6.5 1.5L3 5l3.5 3.5"/></svg> Back</button>`;
    document.getElementById('back-btn')!.addEventListener('click', (e) => { e.stopPropagation(); showList(); });
  }

  // Render list view
  function renderList() {
    listView.innerHTML = projects.map((p, i) => `<div class="widget-project" data-idx="${i}"><div class="project-row"><div class="project-info"><div class="project-name-line"><span class="project-name">${p.name}</span><span class="status-badge ${sc(p.status)}"><span class="status-dot ${dc(p.status)}"></span>${p.status}</span></div><div class="project-desc">${p.desc}</div><div class="project-meta"><span class="branch-badge ${p.branch}">${p.branch}</span><span class="commit-hash">${p.hash}</span><span class="time-ago">${p.time}</span></div></div></div></div>`).join('');

    listView.querySelectorAll('.widget-project').forEach(el => {
      el.addEventListener('click', () => {
        const idx = parseInt(el.getAttribute('data-idx')!);
        showDetail(projects[idx]);
      });
    });
  }

  // Render detail view for a project
  function showDetail(p: Project) {
    // Header: the project summary row
    let html = `<div class="detail-header"><div class="project-info"><div class="project-name-line"><span class="project-name">${p.name}</span><span class="status-badge ${sc(p.status)}"><span class="status-dot ${dc(p.status)}"></span>${p.status}</span></div><div class="project-desc">${p.desc}</div><div class="project-meta"><span class="branch-badge ${p.branch}">${p.branch}</span><span class="commit-hash">${p.hash}</span><span class="time-ago">${p.time}</span></div></div></div>`;

    // Build rows
    html += p.builds.map(b => `<div class="detail-build"><div class="detail-build-top"><span class="status-badge ${sc(b.status)}"><span class="status-dot ${dc(b.status)}"></span>${b.status}</span><span class="detail-build-msg">${b.msg}</span><span class="detail-build-time">${b.time}</span></div><div class="detail-build-bottom"><span class="branch-badge ${b.branch}">${b.branch}</span><span class="commit-hash">${b.hash}</span>${b.dur ? `<span class="detail-build-duration">${b.dur}</span>` : ''}</div></div>`).join('');

    detailView.innerHTML = html;
    detailView.scrollTop = 0;
    renderDetailToolbar();
    widget.classList.add('detail-mode');
  }

  function showList() {
    widget.classList.remove('detail-mode');
    renderListToolbar();
  }

  // Init
  renderListToolbar();
  renderList();

  // Toggle popover
  const trayIcon = document.getElementById('menubar-tray-icon');
  const popover = document.getElementById('widget-popover');

  trayIcon?.addEventListener('click', (e) => {
    e.stopPropagation();
    if (popover && trayIcon) {
      const rect = trayIcon.getBoundingClientRect();
      const centerX = rect.left + rect.width / 2;
      const popoverWidth = 400;
      let left = centerX - popoverWidth / 2;
      left = Math.max(8, Math.min(left, window.innerWidth - popoverWidth - 8));
      popover.style.left = left + 'px';
      popover.style.right = 'auto';
    }
    const isOpen = popover?.classList.toggle('open');
    trayIcon.classList.toggle('active', isOpen);
    // Reset to list view when opening
    if (isOpen) { showList(); }
  });

  document.addEventListener('click', (e) => {
    if (popover?.classList.contains('open') && !popover.contains(e.target as Node) && !trayIcon?.contains(e.target as Node)) {
      popover.classList.remove('open');
      trayIcon?.classList.remove('active');
    }
  });

  // Live clock
  function updateClock() {
    const now = new Date();
    const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
    const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    const h = now.getHours();
    const m = now.getMinutes();
    const ampm = h >= 12 ? 'PM' : 'AM';
    const h12 = h % 12 || 12;
    const el = document.getElementById('menubar-clock');
    if (el) el.textContent = `${days[now.getDay()]} ${now.getDate()} ${months[now.getMonth()]} ${h12}:${m.toString().padStart(2, '0')} ${ampm}`;
  }
  updateClock();
  setInterval(updateClock, 10000);

  // Menu bar dropdowns
  let openDropdown: Element | null = null;
  document.querySelectorAll('.menubar-dropdown > span').forEach(trigger => {
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const dd = trigger.parentElement!;
      if (dd.classList.contains('open')) {
        dd.classList.remove('open');
        openDropdown = null;
      } else {
        openDropdown?.classList.remove('open');
        dd.classList.add('open');
        openDropdown = dd;
      }
    });
    trigger.addEventListener('mouseenter', () => {
      if (openDropdown && openDropdown !== trigger.parentElement) {
        openDropdown.classList.remove('open');
        trigger.parentElement!.classList.add('open');
        openDropdown = trigger.parentElement;
      }
    });
  });
  document.addEventListener('click', () => {
    openDropdown?.classList.remove('open');
    openDropdown = null;
  });

  // Quit = close tab
  document.getElementById('menu-quit')?.addEventListener('click', () => {
    window.close();
  });

  // FAQ = scroll to section
  document.getElementById('menu-faq')?.addEventListener('click', (e) => {
    e.preventDefault();
    openDropdown?.classList.remove('open');
    openDropdown = null;
    document.getElementById('faq')?.scrollIntoView({ behavior: 'smooth' });
  });
</script>
